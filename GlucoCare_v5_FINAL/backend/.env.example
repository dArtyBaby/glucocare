# .env.example
# ─────────────────────────────────────────────────────────────────
# STEP 1: Copy this file:  copy .env.example .env   (Windows)
#                          cp .env.example .env     (Mac/Linux)
# STEP 2: Fill in YOUR values below
# STEP 3: Never commit .env to git — it is in .gitignore
# ─────────────────────────────────────────────────────────────────

# ══ APP ══════════════════════════════════════════════════════════
APP_NAME=GlucoCare API
APP_VERSION=1.0.0
DEBUG=true

# ══ SUPABASE ═════════════════════════════════════════════════════
# Get these from: https://supabase.com/dashboard → your project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_ME
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_ME
# Get from: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# ══ DATABASE ═════════════════════════════════════════════════════
# For LOCAL Docker development (matches docker-compose.yml):
POSTGRES_USER=glucocare
POSTGRES_PASSWORD=glucocare_dev_password_123
POSTGRES_DB=glucocare_db
DATABASE_URL=postgresql+asyncpg://glucocare:glucocare_dev_password_123@db:5432/glucocare_db

# ══ FIREBASE ═════════════════════════════════════════════════════
# Download JSON from: Firebase Console → Project Settings → Service Accounts
FIREBASE_CREDENTIALS_PATH=/app/firebase-adminsdk.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# ══ ML MODEL ═════════════════════════════════════════════════════
MODEL_PATH=ml/xgboost_diabetes_model.joblib
SCALER_PATH=ml/feature_scaler.joblib

# ══ REDIS ════════════════════════════════════════════════════════
REDIS_URL=redis://redis:6379/0

# ══ SECURITY ═════════════════════════════════════════════════════
RATE_LIMIT_PER_MINUTE=60
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
